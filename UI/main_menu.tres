code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D Texture2DParameter : repeat_enable;
uniform sampler2D Gradient;
uniform sampler2D tex_frg_21;



void fragment() {
// ColorConstant:27
	vec4 n_out27p0 = vec4(0.165835, 0.041681, 0.013617, 1.000000);


// Input:2
	vec2 n_out2p0 = UV;


// FloatConstant:9
	float n_out9p0 = 8.284000;


// Input:5
	float n_out5p0 = TIME;


// FloatOp:6
	float n_in6p1 = -0.16000;
	float n_out6p0 = n_out5p0 * n_in6p1;


// FloatOp:20
	float n_in20p1 = -0.12000;
	float n_out20p0 = n_out5p0 * n_in20p1;


// VectorCompose:19
	vec2 n_out19p0 = vec2(n_out6p0, n_out20p0);


// MultiplyAdd:7
	vec2 n_out7p0 = fma(n_out2p0, vec2(n_out9p0), n_out19p0);


	vec4 n_out4p0;
// Texture2D:4
	n_out4p0 = texture(Texture2DParameter, n_out7p0);


// VectorCompose:18
	float n_in18p1 = 0.50000;
	vec2 n_out18p0 = vec2(n_out4p0.x, n_in18p1);


	vec4 n_out17p0;
// Texture2D:17
	n_out17p0 = texture(Gradient, n_out18p0);


// MultiplyAdd:14
	vec3 n_in14p1 = vec3(1.00000, 1.00000, 1.00000);
	vec3 n_in14p2 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out14p0 = fma(vec3(n_out17p0.xyz), n_in14p1, n_in14p2);


// Texture2D:21
	vec4 n_out21p0 = texture(tex_frg_21, UV);


// MultiplyAdd:28
	float n_in28p1 = 1.00000;
	float n_in28p2 = 0.64000;
	float n_out28p0 = fma(n_out21p0.x, n_in28p1, n_in28p2);


// Mix:25
	vec3 n_out25p0 = mix(vec3(n_out27p0.xyz), n_out14p0, vec3(n_out28p0));


// Output:0
	COLOR.rgb = n_out25p0;


}
